# outreach-cli — kopiere zu .env und passe ggf. an.

# Lead-Tracker-Gesamt
SHEET_ID=19ak15Thx3icvmcviMLePG6d22psdWocBChTBNykorL0

# Service-Account-JSON (vom Google-Cloud-Projekt). Pfad mit Umlauten/Leerzeichen OK,
# keine Anführungszeichen drumrum.
GOOGLE_CREDENTIALS_PATH=D:\000 SEO Business\Tools\GoogleAutomationfürAutomtischen schreiben inDokumenten\GoogleSheetMcp\credentials\google-service-account.json

# Primary Tabs: wo Leads "leben" (Stadt-Tabs).
PRIMARY_TABS=Muenchen,Hamburg,Frankfurt,Frankfurt_Umland,Bad Homburg

# Aggregate Tabs: Schatten-Tabs die parallel gepflegt werden (Master-Aggregat).
# Bei set-status wird hier ZUSÄTZLICH zum primary tab geschrieben.
AGGREGATE_TABS=Alle_Leads

# ============================================================
# SMTP (Phase 2: outreach send --test-self / --confirm-live)
# ============================================================
# ProtonMail Bridge oder direct SMTP submission. Token = App-Password aus
# proton-account-Setup (NICHT das User-Password). Token wird NICHT committed.
SMTP_HOST=smtp.protonmail.ch
SMTP_PORT=587
SMTP_USER=georg@maxcontentseo.de
SMTP_TOKEN=REPLACE_ME_WITH_PROTON_APP_PASSWORD

# Owner-Email (Default From-Header + --test-self Empfänger)
OWNER_EMAIL=georg@maxcontentseo.de

# ============================================================
# IMAP via ProtonMail Bridge (für outreach bounce-check)
# ============================================================
# Bridge MUSS lokal laufen (Default-Listener: 127.0.0.1:1143).
# Username = die in Bridge konfigurierte Adresse (NICHT die ProtonMail-Login-Email
# falls die anders ist). Bei "no such user" Fehler: Bridge GUI öffnen und
# exakte Adresse aus "Mailbox configuration" eintragen.
IMAP_HOST=127.0.0.1
IMAP_PORT=1143
PROTON_IMAP_USER=georg@maxcontentseo.de

# Password = das in Bridge GUI angezeigte Mailbox-Password (16 chars uppercase).
# Häufig identisch mit SMTP_TOKEN — Bridge teilt das gleiche Token zwischen
# IMAP und SMTP. Falls Bridge ein eigenes IMAP-Token zeigt, hier eintragen.
# Wenn leer: Fallback-Kette PROTON_IMAP_PASSWORD → SMTP_TOKEN.
PROTONMAIL_BRIDGE_PASSWORD=
