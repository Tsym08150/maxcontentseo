# outreach-cli — kopiere zu .env und passe ggf. an.

# Lead-Tracker-Gesamt
SHEET_ID=19ak15Thx3icvmcviMLePG6d22psdWocBChTBNykorL0

# Service-Account-JSON (vom Google-Cloud-Projekt). Pfad mit Umlauten/Leerzeichen OK,
# keine Anführungszeichen drumrum.
GOOGLE_CREDENTIALS_PATH=D:\000 SEO Business\Tools\GoogleAutomationfürAutomtischen schreiben inDokumenten\GoogleSheetMcp\credentials\google-service-account.json

# Primary Tabs: wo Leads "leben" (Stadt-Tabs).
PRIMARY_TABS=Muenchen,Hamburg,Frankfurt,Frankfurt_Umland,Bad Homburg

# Aggregate Tabs: Schatten-Tabs die parallel gepflegt werden (Master-Aggregat).
# Bei set-status wird hier ZUSÄTZLICH zum primary tab geschrieben.
AGGREGATE_TABS=Alle_Leads
